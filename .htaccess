	RewriteRule ^developerproducts/list$ /core/universes/developerproducts.php [END]
	
	RewriteRule ^game/logout.aspx$ /core/api/logout.php							  [END]
	RewriteRule ^Game/logout.aspx$ /core/api/logout.php							  [END]
	RewriteRule ^api/(.*)$ /core/api/$1.php							  [END]
	
	
	
	RewriteRule ^inbox /mobile/inbox.php							  [END]
	RewriteRule ^home$ /mobile/home.php							  [END]
	RewriteRule ^mobile-app-upgrades/native-ios/bc$ /mobile/nocurrencylol.php							  [END]
	RewriteRule ^mobile-app-upgrades/native-ios/robux$ /mobile/nocurrencylol.php							  [END]
	RewriteRule ^mobile/games$ /mobile/games.php							  [END]
	RewriteRule ^mobile/games/$ /mobile/games.php							  [END]

	RewriteRule ^signup/is-username-valid$ /core/api/mobile/is-username-valid.php [END]
	RewriteRule ^signup/is-password-valid$ /core/api/mobile/is-password-valid.php [END]
	RewriteRule ^UserCheck/getrecommendedusername$ /core/api/mobile/getrecommendedusername.php [END]
	
	RewriteRule ^mobileapi/(.*)/$ /core/api/mobile/$1.php							  [END]
	RewriteRule ^mobileapi/(.*)$ /core/api/mobile/$1.php							  [END]
	
	RewriteRule ^game/maingameserver.ashx$ /core/gamescripts/coregameserver.php [END]
	RewriteRule ^Game/maingameserver.ashx$ /core/gamescripts/coregameserver.php [END]

	RewriteRule ^game/teamcreate.ashx$ /core/gamescripts/teamcreategameserver.php [END]
	RewriteRule ^Game/teamcreate.ashx$ /core/gamescripts/teamcreategameserver.php [END]


	RewriteRule ^Game/Tools/InsertAsset.ashx$ /core/insertasset.php [END]

	RewriteRule ^Friend/AreFriends$ /Friend/AreFriends.php [END]

	RewriteRule ^create/(.*?)$ /create.php?type=$1 [END]
	RewriteRule ^create.php$ /core/error/404.php [END]

	RewriteRule ^UploadMedia/PostImage.aspx /core/uploadmedia/postimage.php [END]
	RewriteRule ^UploadMedia/UploadVideo.aspx /core/uploadmedia/uploadvideo.php [END]

	RewriteRule ^Sets/SetHandler.ashx /core/sets/setshandler.php [END]
	RewriteRule ^sets/SetsHandler.ashx /core/sets/setshandler.php [END]
	RewriteRule ^UploadMedia/UploadVideo.aspx /core/uploadmedia/uploadvideo.php [END]

	RewriteRule ^Game/Tools/ThumbnailAsset.ashx /images/unavailable-75.png [END]
	RewriteRule ^game/Tools/ThumbnailAsset.ashx /images/unavailable-75.png [END]
	RewriteRule ^Thumbs/Avatar.ashx /core/thumbs/player.php [END]
	RewriteRule ^thumbs/avatar.ashx /core/thumbs/player.php [END]

	RewriteRule ^Thumbs/RawAsset.ashx /core/thumbs/rawasset.php [END]
	RewriteRule ^thumbs/RawAsset.ashx /core/thumbs/rawasset.php [END]
	RewriteRule ^Thumbs/Asset.ashx /core/thumbs/rawasset.php [END]
	RewriteRule ^thumbs/Asset.ashx /core/thumbs/rawasset.php [END]
	RewriteRule ^thumbs/?$ /core/thumbs/index.php [END]
	RewriteRule ^thumbs/player?$ /core/thumbs/player.php [END]
	RewriteRule ^thumbs/profile?$ /core/thumbs/profile.php [END]

	RewriteRule ^thumbnail/avatar-headshot?$ /core/thumbs/headshot.php [END]

	RewriteRule ^marketplace/productinfo$ /core/marketplace/productinfo.php [END]
	RewriteRule ^marketplace/productDetails$ /core/marketplace/productinfo.php [END]
	RewriteRule ^ownership/hasasset$ /core/marketplace/hasasset.php [END]
	
	RewriteRule ^download/thankyou$ /download/thankyou.php [END]
	RewriteRule ^moderation/v2/filtertext$  /core/moderation/filtertext.php [END]
	RewriteRule ^moderation/v2/filtertext/$ /core/moderation/filtertext.php [END]
	RewriteRule ^moderation/filtertext/     /core/moderation/filtertext.php [END]
	RewriteRule ^/moderation/filtertext/    /core/moderation/filtertext.php [END]

	RewriteRule ^edit$ /edit.php [END]

	RewriteCond %{QUERY_STRING} id=(.+)
	RewriteRule ^(.*)-item$ /item.php?name=$1&id=%1 [QSD,END]
	RewriteCond %{QUERY_STRING} id=(.+)
	RewriteRule ^(.*)-place$ /place.php?name=$1&id=%1 [QSD,END]
	
	RewriteRule ^Asset/BodyColors.ashx$ /core/character/bodycolors.php 			  [END]
	RewriteRule ^Asset/CharacterFetch.ashx$ /core/character/characterfetch.php 			  [END]
	RewriteRule ^Asset/GetScriptState.ashx$ /core/gamescripts/getscriptstate.txt 			  [END]

	# SHUT THE FUCK UPP!!!!!
	RewriteRule ^Error/Dmp.ashx$ /core/nothing.txt [END]
	RewriteRule ^v1.1/Counters/Increment/?$ /core/nothing.txt [END]
	RewriteRule ^v1.1/counters/increment/?$ /core/nothing.txt [END]
	RewriteRule ^game/report-stats?$ /core/nothing.txt [END]
	RewriteRule ^Game/report-stats?$ /core/nothing.txt [END]
	RewriteRule ^game/validate-machine?$ /core/success.txt [END]
	RewriteRule ^Game/validate-machine?$ /core/success.txt [END]

	RewriteRule ^game/MachineConfiguration.ashx?$ /core/authentication/machineconfiguration.txt [END]
	RewriteRule ^Game/MachineConfiguration.ashx?$ /core/authentication/machineconfiguration.txt [END]

	RewriteRule ^game/PlaceLauncher.ashx?$ /core/gamescripts/placelauncher.php [END]
	RewriteRule ^Game/PlaceLauncher.ashx?$ /core/gamescripts/placelauncher.php [END]
	RewriteRule ^game/PlaceLauncher.ashx/?$ /core/gamescripts/placelauncher.php [END]
	RewriteRule ^Game/PlaceLauncher.ashx/?$ /core/gamescripts/placelauncher.php [END]
	
	RewriteRule ^game/([0-9]+)$ /place.php?name=a&id=$1 [END]
	RewriteRule ^Game/([0-9]+)$ /place.php?name=a&id=$1 [END]

	RewriteRule ^games$ /games.php [END]
	RewriteRule ^catalog$ /catalog.php [END]

	RewriteRule ^test$ /test.php [END]

	RewriteRule ^games.php$ /core/error/404.php [END]
	RewriteRule ^games.php$ /core/error/404.php [END]
	RewriteRule ^catalog.php$ /core/error/404.php [END]
	RewriteRule ^edit.php$ /core/error/404.php [END]
	RewriteRule ^item.php$ /core/error/404.php [END]
	RewriteRule ^place.php$ /core/error/404.php [END]
	RewriteRule ^README.md$ /core/error/404.php [END]

	RewriteRule ^GetAllowedMD5Hashes/$ /core/authentication/getallowedmd5hashes.php [END]
	RewriteRule ^GetAllowedSecurityKeys/$ /core/authentication/getallowedsecuritykeys.php [END]
	RewriteRule ^GetAllowedSecurityVersions/$ /core/authentication/getallowedsecurityversions.php [END]

	RewriteRule ^core/error/404.php /core/error/404.php [END]
	
	RewriteRule ^Admin/components/(.*)$ Admin/components/$1.php [END]

	RewriteRule ^core(/.*)?$ /core/error/404.php [END]
	RewriteRule ^api(/.*)?$ /core/error/404.php  [END]
</IfModule>

DirectoryIndex index.php index.html Default.aspx Default.aspx.php
ErrorDocument 404 /core/error/404.php
ErrorDocument 500 /core/error/500.php