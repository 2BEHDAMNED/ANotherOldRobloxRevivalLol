	RewriteRule ^user/unfollow /core/social/unfollow.php [END]
	RewriteRule ^user/request-friendship /core/social/request-friendship.php [END]
	RewriteRule ^user/decline-friend-request /core/social/decline-friend-request.php [END]
	
	RewriteRule ^login$ login.php										  [END]
	RewriteRule ^Login$ login.php										  [END]
	RewriteRule ^register$ register.php									  [END]
	RewriteRule ^people$ people.php										  [END]

	RewriteRule ^my/home$ /my/home.php									  [END]
	RewriteRule ^my/stuff$ /my/stuff.php									  [END]
	RewriteRule ^my/profile$ /my/profile.php							  [END]
	RewriteRule ^my/places$ /my/places.php							  [END]
	RewriteRule ^my/character$ /my/character.php							  [END]
	RewriteRule ^my/friends$ /my/friends.php							  [END]
	RewriteRule ^my/settings/json /core/authentication/settings.php [END]

	RewriteRule ^universes/get-universe-containing-place /core/universes/get-universe-containing-place.php [END]
	RewriteRule ^universes/([0-9]+)/cloudeditenabled /core/universes/cloudeditenabled.php?universeId=$1 [END]
	RewriteRule ^universes/([0-9]+)/game-start-info /core/universes/game-start-info.php [END]
	RewriteRule ^universes/([0-9]+)/enablecloudedit /core/universes/enablecloudedit.php?universeId=$1 [END]
