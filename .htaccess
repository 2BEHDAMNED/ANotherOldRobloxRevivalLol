	RewriteRule ^game/logout.aspx$ /api/logout.php							  [END]
	RewriteRule ^Game/logout.aspx$ /api/logout.php							  [END]
	RewriteRule ^api/(.*)$ /core/api/$1.php							  [END]
	
	
	
	RewriteRule ^inbox /mobile/inbox.php							  [END]
	RewriteRule ^home$ /mobile/home.php							  [END]
	RewriteRule ^mobile-app-upgrades/native-ios/bc$ /mobile/nocurrencylol.php							  [END]
	RewriteRule ^mobile-app-upgrades/native-ios/robux$ /mobile/nocurrencylol.php							  [END]
