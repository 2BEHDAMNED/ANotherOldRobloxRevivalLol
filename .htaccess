	RewriteRule ^game/Tools/ThumbnailAsset.ashx /images/unavailable-75.png [END]
	RewriteRule ^Thumbs/Avatar.ashx /core/thumbs/player.php [END]

	RewriteRule ^Thumbs/RawAsset.ashx /core/thumbs/rawasset.php [END]
	RewriteRule ^thumbs/RawAsset.ashx /core/thumbs/rawasset.php [END]
