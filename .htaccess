# User pages :)
<IfModule mod_rewrite.c>
    RewriteEngine on 
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d

	RewriteRule ^users/([0-9]+)/profile$ /users/profile.php?id=$1		  [END]

	RewriteRule ^users/([0-9]+)$  /users/profile.php?id=$1&redirect=true  [END]
	RewriteRule ^users/([0-9]+)/$ /users/profile.php?id=$1&redirect=true  [END]
	
	RewriteRule ^users/([0-9]+)/friends?(.*) /users/friends.php?id=$1&$2  [QSA, END]
	RewriteRule ^users/([0-9]+)/friends$ /users/friends.php?id=$1  [END]
	RewriteRule ^users/([0-9]+)/followers$ /users/followers.php?id=$1  [END]
	RewriteRule ^users/([0-9]+)/following$ /users/following.php?id=$1  [END]
	RewriteRule ^users/([0-9]+)/canmanage/([0-9]+)$ /users/canmanage.php?userId=$1&placeId=$2  [END]
	RewriteRule ^users/([0-9]+)/canmanage/([0-9]+)/$ /users/canmanage.php?userId=$1&placeId=$2  [END]

	RewriteRule ^Users/([0-9]+)$ /users/data.php?id=$1  [END]

	RewriteRule ^users/get-by-username$ /users/get-by-username.php  [END]
	
	RewriteRule ^Game/players/([0-9]+)$ /users/players.php?userId=$1  [END]
	RewriteRule ^game/players/([0-9]+)$ /users/players.php?userId=$1  [END]
	RewriteRule ^Game/players/([0-9]+)/$ /users/players.php?userId=$1  [END]
	RewriteRule ^game/players/([0-9]+)/$ /users/players.php?userId=$1  [END]

	RewriteRule ^asset/?$ /core/utilities/assetdeliverer.php			  [END]
	RewriteRule ^Asset/?$ /core/utilities/assetdeliverer.php 			  [END]
	
	RewriteRule ^IDE/Landing.aspx$ /core/ide/landing.php				  		  [END]
	RewriteRule ^ide/welcome$ /my/places.php				  		  [END]
	RewriteRule ^IDE/welcome$ /my/places.php				  		  [END]
	RewriteRule ^My/Place.aspx$ /my/places.php				  		  [END]

	RewriteRule ^IDE/Upload.aspx$ /core/ide/publish.php				  		  [END]
	RewriteRule ^ide/publish$ /core/ide/publish.php				  		  [END]
	RewriteRule ^IDE/PublishNewPlace.aspx$ /core/ide/publishnewplace.php				  		  [END]
	RewriteRule ^IDE/ClientToolbox.aspx	/core/ide/toolbox.php			  [END]

